# ==============================
# Docker Compose - Variables de Ambiente
# ==============================

# --- Docker Hub ---
DOCKERHUB_USER=firnex

# --- Base de Datos (PostgreSQL) ---
DB_URL=jdbc:postgresql://db:5432/clonmocky
DB_USERNAME=clonmocky
DB_PASSWORD=clonmocky
DB_NAME=clonmocky
DB_DRIVER=org.postgresql.Driver

# --- Volumen de datos (ruta en el host) ---
DB_DATA_PATH=./pgdata

# --- Puerto de la aplicación en el host ---
APP_PORT=8080

# --- JPA / Hibernate ---
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# --- JWT ---
JWT_SECRET=Y2xvbi1tb2NreS1zZWNyZXQta2V5LXByYWN0aWNhLTIwMjUtc3ByaW5nLWJvb3Q=
JWT_EXPIRATION=60

# --- PgAdmin ---
PGADMIN_PORT=8082
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
